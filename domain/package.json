{
  "name": "gs-engineer-dashboard-domain",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "bundle": "npx @redocly/cli bundle openapi.yaml -o generated/openapi.bundled.yaml",
    "generate:aspida": "openapi2aspida --input generated/openapi.bundled.yaml",
    "generate:zod": "openapi-zod-client generated/openapi.bundled.yaml -o generated/zod/schemas.ts",
    "generate:msw": "msw init generated/msw",
    "generate": "npm run bundle && npm run generate:aspida && npm run generate:zod && npm run generate:msw"
  },
  "devDependencies": {
    "openapi2aspida": "latest",
    "openapi-zod-client": "latest",
    "msw": "latest"
  }
}
